NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://azmarineberg:azmarineberg_dev@localhost:5432/azmarineberg_portal

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# S3 / MinIO (set STORAGE_TYPE=local for dev without MinIO)
STORAGE_TYPE=local
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=azmarineberg
S3_SECRET_KEY=azmarineberg_dev
S3_BUCKET=azmarineberg-documents
S3_REGION=us-east-1
S3_USE_SSL=false

# ---------------------------------------------------------------------------
# Email / SMTP (Nodemailer — used for password reset + client onboarding)
# ---------------------------------------------------------------------------
# Local dev: optional. Production API (e.g. Render): set all of SMTP_* below.
#
# SendGrid (recommended):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   SMTP_FROM=no-reply@your-verified-sender-domain.com
#
# If Render logs show ETIMEDOUT on SMTP connection, try implicit TLS:
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@azmarineberg.com

# Public URL of the *frontend* (Vercel). Used in reset/invite links and CORS.
# Production: https://your-app.vercel.app
APP_URL=http://localhost:5173

# Optional: extra allowed browser origins (comma-separated), e.g. Vercel preview URLs
# CORS_ORIGINS=https://azmarineberg-portal-xxx.vercel.app

# Password reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=20

# Client onboarding / invite links (hours, clamped to 24-48)
INVITE_TOKEN_TTL_HOURS=48
